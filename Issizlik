<script>
(function(){
  var nt=document.getElementById('nav-toggle'),mn=document.getElementById('mobile-nav');
  if(nt&&mn){nt.addEventListener('click',function(){mn.classList.toggle('open');});document.addEventListener('click',function(e){if(!nt.contains(e.target)&&!mn.contains(e.target))mn.classList.remove('open');});}
  var faqs=document.querySelectorAll('.faq-q');
  for(var i=0;i<faqs.length;i++) faqs[i].addEventListener('click',function(){this.parentElement.classList.toggle('open');});

  var ASG_BRUT = 33030;
  function fmt(n){return n.toLocaleString('tr-TR',{minimumFractionDigits:2,maximumFractionDigits:2})+' TL';}

  function getOdemeSuresi(gun){
    if(gun>=1080) return 300;
    if(gun>=900)  return 240;
    if(gun>=600)  return 180;
    return 0;
  }

  function calculate(){
    var brut  = parseFloat(document.getElementById('brut-maas').value);
    var gun   = parseFloat(document.getElementById('prim-gun').value);
    var neden = document.getElementById('ayrilma').value;

    if(!brut||brut<=0){alert('Lutfen brut maas giriniz.');return;}
    if(!gun||gun<=0){alert('Lutfen prim gun sayisi giriniz.');return;}

    if(neden === 'haksiz-fesih' && gun < 600){
      alert('Issizlik odenegi icin en az 600 prim gununuz olmasi gerekmektedir.');
      return;
    }

    var sure = getOdemeSuresi(gun);
    if(sure === 0){
      document.getElementById('odeme-amt').innerHTML = 'Hak Yok<span></span>';
      var h = '<div class="result-row"><span class="rname">Sonuc</span><span class="rval" style="color:var(--red)">600 gun sartini saglamiyorsunuz</span></div>';
      document.getElementById('rows').innerHTML = h;
      var el=document.getElementById('results');el.className='card show animate-in';el.scrollIntoView({behavior:'smooth',block:'nearest'});
      return;
    }

    // Hesaplama: brut maasin %40'i
    var aylikOdeme = brut * 0.40;
    // Alt limit: asgari ucretin %80'i
    var altLimit = ASG_BRUT * 0.80 * 0.85; // net yaklasik
    // Ust limit: asgari ucretin %80'i x 4
    var ustLimit = altLimit * 4;

    aylikOdeme = Math.max(aylikOdeme, altLimit);
    aylikOdeme = Math.min(aylikOdeme, ustLimit);

    var toplamOdeme = aylikOdeme * (sure/30);

    document.getElementById('odeme-amt').innerHTML = aylikOdeme.toLocaleString('tr-TR',{maximumFractionDigits:2})+'<span> TL</span>';

    var rows=[
      {n:'Son Brut Maas',                v:fmt(brut),            c:''},
      {n:'Odeme Orani',                  v:'Brut maasin %40\'i', c:''},
      {n:'Hesaplanan Tutar',             v:fmt(brut*0.40),       c:''},
      {n:'Alt Limit (Asg. Ucr. x %80)', v:fmt(altLimit),        c:''},
      {n:'Ust Limit (Alt Limit x 4)',    v:fmt(ustLimit),        c:''},
      {n:'Aylik Issizlik Odenegi',       v:fmt(aylikOdeme),      c:'purple'},
      {n:'Odeme Suresi',                 v:sure+' gun ('+(sure/30)+' ay)', c:''},
      {n:'Tahmini Toplam Odeme',         v:fmt(toplamOdeme),     c:'green'}
    ];

    var h='';
    for(var i=0;i<rows.length;i++) h+='<div class="result-row"><span class="rname">'+rows[i].n+'</span><span class="rval '+rows[i].c+'">'+rows[i].v+'</span></div>';
    document.getElementById('rows').innerHTML=h;
    var el=document.getElementById('results');el.className='card show animate-in';el.scrollIntoView({behavior:'smooth',block:'nearest'});
  }

  document.getElementById('calc-btn').addEventListener('click',calculate);
  document.addEventListener('keypress',function(e){if(e.key==='Enter')calculate();});
})();
</script>
</body>
</html>
